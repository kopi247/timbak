# Solana RPC HTTP endpoint (fast, reliable – Helius, QuickNode, etc.)
RPC_HTTP=https://mainnet.helius-rpc.com/?api-key=your-api-key

# Your wallet private key (as comma-separated bytes list)
# Example: 34,56,78,...  (bytes of the keypair)
PRIVATE_KEY=0,0,0,...

# Jito block engine URL
JITO_BUNDLE_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles

# (Optional) Jito auth header if required by your tier
JITO_AUTH_HEADER=

# Snipe amount in SOL per token
SNIPE_AMOUNT_SOL=0.05

# Slippage in basis points (100 = 1%)
SLIPPAGE_BPS=2500

# Jito tip in lamports (minimum 1_000_000 recommended during high activity)
TIP_LAMPORTS=1000000

# Safety check: minimum RugCheck score to pass (0 = no risks, 1 = low, etc.)
MAX_RUGCHECK_RISK=0
